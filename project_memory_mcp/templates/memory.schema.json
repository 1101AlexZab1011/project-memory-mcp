{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "project-memory.schema.json",
  "title": "Project Memory",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "status",
    "description",
    "tags",
    "labels",
    "scope",
    "triggers",
    "remembered_facts",
    "solution_pattern",
    "pitfalls",
    "evidence",
    "relationships"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "stale",
        "superseded",
        "wrong"
      ]
    },
    "description": {
      "type": "string",
      "minLength": 20
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
      },
      "uniqueItems": true
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z]+:[a-z0-9]+(-[a-z0-9]+)*$"
      },
      "uniqueItems": true,
      "minItems": 1
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project",
        "area",
        "files"
      ],
      "properties": {
        "project": {
          "type": "string"
        },
        "area": {
          "type": "string"
        },
        "files": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "applies_to": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "triggers": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true,
      "minItems": 1
    },
    "remembered_facts": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "solution_pattern": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "pitfalls": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "created_from_task",
        "last_validated"
      ],
      "properties": {
        "created_from_task": {
          "type": "string"
        },
        "last_validated": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        }
      }
    },
    "relationships": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "related",
        "supersedes",
        "superseded_by"
      ],
      "properties": {
        "related": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "reason"],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
              },
              "reason": {
                "type": "string",
                "minLength": 10
              }
            }
          }
        },
        "supersedes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "superseded_by": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    }
  }
}
